# ============================================================
#  ライフメイクセールス 環境変数テンプレート
#  使い方: このファイルを「.env」という名前でコピーし、値を設定する。
#         （.env は git 管理外。秘密情報はここに書かない）
#  ※何も設定しなくても DEMO_MODE=true で全機能を試せます。
# ============================================================

# --- ログイン認証 ---
# 空ならログイン不要（ローカル単独利用）。ネット公開時は必ず設定すること。
# 初回起動時、この値で管理者ユーザー(admin)が自動作成される。
APP_PASSWORD=

# --- AI 全般 ---
# true  = AIはサンプル動作（APIキー不要・無料でお試し）
# false = 本物のAIを使う（下の各キーが必要）
DEMO_MODE=true

# 議事録生成・タスク抽出・カルテ振り分け・提案トーク（Anthropic Claude）
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# 音声の文字起こし（OpenAI Whisper クラウド）
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1

# 話者分離（任意・AssemblyAI）
ASSEMBLYAI_API_KEY=
DIARIZE_LANGUAGE=ja

# --- ローカル文字起こし（無料・キー不要） ---
# true にすると faster-whisper でPC内文字起こし（whisper_venv が必要）。
# 別PCで使うには setup_whisper.bat で whisper_venv を作ること。
LOCAL_WHISPER=false
WHISPER_LOCAL_MODEL=small
# 選択肢: tiny / base / small / medium（大きいほど高精度・低速）

# --- 外部CRM連携（任意・HubSpot） ---
# HubSpot の Private App トークン。設定すると CRM画面から同期できる。
HUBSPOT_TOKEN=

# --- データ保存先（クラウド等で永続ディスクに向ける場合のみ） ---
# 未設定ならアプリと同じフォルダに sales_tool.db / data/uploads を作る。
# DATABASE_PATH=/data/sales_tool.db
# UPLOAD_DIR=/data/uploads
# MAX_UPLOAD_MB=500
